# ── Sober config — `cp .env.example .env` then fill ONE of the sections below ──

# ════════════════════════════════════════════════════════════════════════════
# OPTION 1 — Cognee Cloud  (Track 2 · iPhone)   ← your pick
# Sign up at https://my.cognee.ai, redeem credit code COGNEE-35, create an API
# key, and copy your instance URL. No local LLM key needed — Cloud handles it.
# ════════════════════════════════════════════════════════════════════════════
COGNEE_CLOUD_URL="https://<your-instance>.cognee.ai"
COGNEE_CLOUD_API_KEY="your-cloud-api-key"

# ════════════════════════════════════════════════════════════════════════════
# OPTION 2 — Local open-source Cognee  (Track 1 · MacBook)
# Leave the two COGNEE_CLOUD_* lines blank/removed and set an LLM key instead.
# ════════════════════════════════════════════════════════════════════════════
# OpenAI (easiest, ~a few cents):
# LLM_PROVIDER="openai"
# LLM_MODEL="openai/gpt-4o-mini"
# LLM_API_KEY="sk-your-openai-key"
#
# OR Google Gemini (free; needs: pip install "cognee[gemini]"):
# LLM_PROVIDER="gemini"
# LLM_MODEL="gemini/gemini-2.0-flash"
# LLM_API_KEY="your-gemini-key"
# EMBEDDING_PROVIDER="gemini"
# EMBEDDING_MODEL="gemini/text-embedding-004"
# EMBEDDING_API_KEY="your-gemini-key"

# Single-user mode: no auth, shared local DBs (simplest for the demo)
ENABLE_BACKEND_ACCESS_CONTROL="false"
